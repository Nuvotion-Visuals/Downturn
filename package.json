{
  "name": "downturn",
  "version": "2.0.0",
  "type": "module",
  "description": "Web page to markdown with zero dependencies — 99% less code than the original",
  "main": "index.mjs",
  "bin": {
    "downturn": "./mcp.mjs"
  },
  "scripts": {
    "start": "node index.mjs",
    "test": "node --test tests/*.test.mjs",
    "dev": "node --watch index.mjs",
    "mcp": "node mcp.mjs",
    "worker:dev": "PORT=4001 node worker.mjs",
    "worker:bundle": "npx esbuild worker.mjs --bundle --outfile=dist/worker.js --format=esm --external:node:http"
  },
  "author": "Tom Leamon",
  "repository": {
    "type": "git",
    "url": "https://github.com/tom-leamon/downturn"
  },
  "license": "MIT"
}
