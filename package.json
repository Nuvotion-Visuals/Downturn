{
  "name": "downturn",
  "version": "2.1.3",
  "type": "module",
  "description": "Markdown web browser and editor",
  "main": "index.mjs",
  "bin": {
    "downturn": "./mcp.mjs"
  },
  "scripts": {
    "start": "node index.mjs",
    "test": "node --test tests/*.test.mjs",
    "dev": "PORT=4001 node --watch worker.mjs",
    "mcp": "node mcp.mjs",
    "worker:bundle": "npx esbuild worker.mjs --bundle --outfile=dist/worker.js --format=esm --external:node:http",
    "ext:build": "node extension/build.mjs"
  },
  "author": "Tom Leamon",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nuvotion-Visuals/Downturn"
  },
  "license": "MIT",
  "files": [
    "*.mjs",
    "lib/"
  ]
}
